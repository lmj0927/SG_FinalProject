  - id: 59
    text: "\uC11C\uC5F0\uC774\uAC00 \uD658\uD558\uAC8C \uC6C3\uC73C\uBA70 \uB0B4
      \uBC18\uD2F0 \uC18C\uB9E4\uB97C \uC7A5\uB09C\uC2A4\uB808 \uB04C\uC5B4\uB2F9\uACBC\uACE0,
      \uC11D\uC9C4\uC774\uC640 \uB2E4\uB978 \uB0A8\uD559\uC0DD\uB4E4\uB3C4 \uB0B4
      \uC5B4\uAE68\uB97C \uD22D\uD22D \uAC10\uC2F8 \uC548\uC558\uB2E4."
    trigger: 0
    nextId: 60
    motionType: 0
    characterType: 7
    backgroundType: 5
    c1Label: 
    c1NextId: 
    c2Label: 
    c2NextId: 
    c3Label: 
    c3NextId: 
  - id: 60
    text: "\uCC28\uAC00\uC6B4 \uB178\uC774\uC988\uB85C\uB9CC \uAC00\uB4DD\uD588\uB358
      \uAD50\uC2E4\uC758 \uC8FC\uD30C\uC218\uAC00, \uCC98\uC74C\uC73C\uB85C \uB530\uB73B\uD55C
      \uD654\uC74C\uC774 \uB418\uC5B4 \uB098\uB97C \uAC10\uC2F8\uB294 \uB4EF\uD55C
      \uAE30\uC774\uD558\uACE0\uB3C4 \uBC85\uCC2C \uAC10\uAC01\uC774\uC5C8\uB2E4."
    trigger: 0
    nextId: 61
    motionType: 0
    characterType: 7
    backgroundType: 5
    c1Label: 
    c1NextId: 
    c2Label: 
    c2NextId: 
    c3Label: 
    c3NextId: 
  - id: 61
    text: "\uC6B4\uB3D9\uC7A5 \uC800\uD3B8\uC5D0\uC11C \uADF8 \uBAA8\uC2B5\uC744
      \uD750\uBB47\uD558\uAC8C \uC9C0\uCF1C\uBCF4\uB358 \uD558\uC9C4\uC774\uAC00,
      \uC5B4\uB290\uC0C8 \uC74C\uB8CC\uC218 \uCE94\uC744 \uC591\uC190\uC5D0 \uB4E4\uACE0
      \uB2E4\uAC00\uC640 \uB0B4 \uBAA9\uC5D0 \uB540\uC218\uAC74\uC744 \uCC99 \uAC78\uCCD0\uC8FC\uBA70
      \uD2B9\uC720\uC758 \uB2A5\uAE00\uB9DE\uC740 \uBBF8\uC18C\uB97C \uC9C0\uC5C8\uB2E4."
    trigger: 0
    nextId: 62
    motionType: 0
    characterType: 7
    backgroundType: 5
    c1Label: 
    c1NextId: 
    c2Label: 
    c2NextId: 
    c3Label: 
    c3NextId: 
  - id: 62
    text: "\uC57C, \uC9C0\uCC2C\uC218. \uB108 \uC624\uB298 \uC904 \uB3CC\uB9AC\uB294
      \uAC70 \uC194\uC9C1\uD788 \uC804\uAD50\uC5D0\uC11C \uC81C\uC77C \uBA4B\uC788\uC5C8\uB2E4?"
    trigger: 0
    nextId: 63
    motionType: 1
    characterType: 3
    backgroundType: 5
    c1Label: 
    c1NextId: 
    c2Label: 
    c2NextId: 
    c3Label: 
    c3NextId: 
  - id: 63
    text: "\uAC8C\uB2E4\uAC00 \uB3C4\uB9DD\uB3C4 \uC548 \uCE58\uACE0 \uC560\uB4E4
      \uB208 \uBCF4\uBA74\uC11C \uACE0\uB9D9\uB2E4\uACE0 \uB9D0\uAE4C\uC9C0 \uD558\uB0D0?
      \uB098 \uC9C4\uC9DC \uB208\uBB3C \uB0A0 \uBED4\uD568."
    trigger: 0
    nextId: 64
    motionType: 1
    characterType: 3
    backgroundType: 5
    c1Label: 
    c1NextId: 
    c2Label: 
    c2NextId: 
    c3Label: 
    c3NextId: 
  - id: 64
    text: "...\uC2DC\uB044\uB7EC, \uC778\uB9C8. \uD314 \uC544\uD504\uB2C8\uAE4C \uB9D0
      \uC2DC\uD0A4\uC9C0 \uB9C8."
    trigger: 0
    nextId: 65
    motionType: 0
    characterType: 1
    backgroundType: 5
    c1Label: 
    c1NextId: 
    c2Label: 
    c2NextId: 
    c3Label: 
