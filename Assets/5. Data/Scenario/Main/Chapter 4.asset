  nodes:
  - id: 0
    text: "\uCCB4\uC721\uB300\uD68C \uB2F9\uC77C. \uD65C\uAE30\uCC2C \uD568\uC131\uC18C\uB9AC\uC640
      \uD638\uAC01 \uC18C\uB9AC\uAC00 \uAC00\uB4DD\uD55C \uD559\uAD50 \uC6B4\uB3D9\uC7A5\uC5D0\uC11C\uB294
      \uB9CC\uAD6D\uAE30\uAC00 \uD718\uB0A0\uB9AC\uACE0 \uBD04 \uD587\uC0B4\uC774
      \uC804\uACBD\uC744 \uB530\uC2A4\uD558\uAC8C \uB0B4\uB9AC\uCB10\uACE0 \uC788\uB2E4."
    trigger: 0
    nextId: 1
    motionType: 0
    characterType: 7
    backgroundType: 5
    c1Label: 
    c1NextId: 
    c2Label: 
    c2NextId: 
    c3Label: 
    c3NextId: 
  - id: 1
    text: "\uD558\uC9C0\uB9CC \uB208\uBD80\uC2E0 \uBD04 \uD48D\uACBD\uACFC \uB2EC\uB9AC,
      \uB098\uC5D0\uAC8C \uC6B4\uB3D9\uC7A5\uC740 \uADF8\uC57C\uB9D0\uB85C \uAC00\uC7A5
      \uAC70\uB300\uD558\uACE0 \uD639\uD639\uD55C \uC2DC\uD5D8\uB300\uC600\uB2E4.
      \uC804\uAD50\uC0DD\uC774 \uD55C\uC790\uB9AC\uC5D0 \uBAA8\uC5EC \uC0AC\uBC29\uC5D0\uC11C
      \uC18C\uB9AC\uB97C \uC9C0\uB974\uACE0 \uC788\uC5C8\uACE0, \uC751\uC6D0 \uB3C4\uAD6C\uAC00
      \uBD80\uB52A\uCE58\uB294 \uC18C\uB9AC, \uC570\uD504\uC5D0\uC11C \uD758\uB7EC\uB098\uC624\uB294
      \uB304\uC2A4\uACE1\uC774 \uB4A4\uC11E\uC5EC \uACE0\uB9C9\uC744 \uCC14\uB800\uB2E4."
    trigger: 0
    nextId: 2
    motionType: 0
    characterType: 7
    backgroundType: 5
    c1Label: 
    c1NextId: 
    c2Label: 
    c2NextId: 
    c3Label: 
    c3NextId: 
  - id: 2
    text: "\uC0AC\uBC29\uC5D0\uC11C \uBAA8\uB974\uB294 \uC544\uC774\uB4E4\uC774 \uC5B4\uAE68\uB97C
      \uBD80\uB52A\uCE58\uBA70 \uC9C0\uB098\uAC08 \uB54C\uB9C8\uB2E4 \uB0B4 \uBAB8\uC758
      \uBAA8\uB4E0 \uAC10\uAC01 \uC138\uD3EC\uAC00 \uBE44\uBA85\uC744 \uC9C0\uB974\uB294
      \uAC83 \uAC19\uC558\uB2E4."
    trigger: 0
    nextId: 3
    motionType: 0
    characterType: 7
    backgroundType: 5
    c1Label: 
    c1NextId: 
    c2Label: 
    c2NextId: 
    c3Label: 
    c3NextId: 
  - id: 3
    text: "\uC608\uC804 \uAC19\uC558\uC73C\uBA74 \uC9C4\uC791\uC5D0 \uBCF4\uAC74\uC2E4\uB85C
      \uB3C4\uB9DD\uCCD0 \uACFC\uD638\uD761 \uBA85\uB2E8\uC5D0 \uC774\uB984\uC744
      \uC62C\uB838\uC744 \uC0C1\uD669\uC774\uC5C8\uB2E4."
    trigger: 0
    nextId: 4
    motionType: 0
    characterType: 7
    backgroundType: 5
    c1Label: 
    c1NextId: 
    c2Label: 
    c2NextId: 
    c3Label: 
    c3NextId: 
  - id: 4
    text: "\uC2A4\uD53C\uCEE4: \uB2E4\uC74C \uACBD\uAE30, 1\uD559\uB144 \uB2E8\uCCB4
      \uC904\uB118\uAE30 \uC608\uC120\uC804 \uC9C4\uD589\uD558\uACA0\uC2B5\uB2C8\uB2E4!
      \uAC01 \uBC18 \uC120\uC218\uB4E4\uC740 \uC6B4\uB3D9\uC7A5 \uC911\uC559\uC73C\uB85C
      \uBAA8\uC5EC\uC8FC\uC138\uC694!"
    trigger: 0
    nextId: 5
    motionType: 0
    characterType: 7
    backgroundType: 5
    c1Label: 
    c1NextId: 
    c2Label: 
    c2NextId: 
    c3Label: 
    c3NextId: 
  - id: 5
    text: "\uBCF8\uBD80\uC11D\uC758 \uBC29\uC1A1 \uC2A4\uD53C\uCEE4\uB97C \uD1B5\uD574
      \uC548\uB0B4 \uBA58\uD2B8\uAC00 \uCC22\uC5B4\uC9C0\uB294 \uC18C\uB9AC\uB85C
      \uC6B8\uB824 \uD37C\uC9C0\uC790, \uAFB9 \uB20C\uB7EC \uB2F4\uACE0 \uC788\uB358
      \uB0B4 \uC2EC\uC7A5\uC774 \uB2E4\uC2DC\uAE08 \uCFF5\uCF85\uAC70\uB9AC\uBA70
      \uD130\uC9C8 \uB4EF\uC774 \uB6F0\uAE30 \uC2DC\uC791\uD588\uB2E4."
    trigger: 0
    nextId: 6
    motionType: 0
    characterType: 7
    backgroundType: 5
    c1Label: 
    c1NextId: 
    c2Label: 
    c2NextId: 
    c3Label: 
    c3NextId: 
  - id: 6
    text: "\uC190\uBC14\uB2E5\uC5D0 \uCC28\uAC00\uC6B4 \uC2DD\uC740\uB540\uC774 \uCC28\uC62C\uB790\uACE0,
      \uC6B4\uB3D9\uC7A5\uC758 \uB113\uC740 \uACF5\uAC04\uC774 \uAC11\uC790\uAE30
      \uB098\uB97C \uC555\uB3C4\uD558\uBA70 \uC5B4\uC9C0\uB7EC\uC6C0\uC774 \uBC00\uB824\uC654\uB2E4."
    trigger: 0
    nextId: 7
