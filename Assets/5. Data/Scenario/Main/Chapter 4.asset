    c1NextId: 
    c2Label: 
    c2NextId: 
    c3Label: 
    c3NextId: 
  - id: 70
    text: "\uC544\uC774\uB4E4\uC740 \uC800\uB9C8\uB2E4 \uB540\uC5D0 \uC816\uC740
      \uBC18\uD2F0\uB97C \uAC08\uC544\uC785\uAC70\uB098 \uAC00\uBC29\uC744 \uCC59\uAE30\uBA70
      \uAD50\uC2E4\uB85C \uD5A5\uD588\uB2E4."
    trigger: 0
    nextId: 71
