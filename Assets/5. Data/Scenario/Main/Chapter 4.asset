  - id: 7
    text: "\uCC2C\uC218\uC57C, \uC0AC\uBC29\uC774 \uC644\uC804\uD788 \uC5F4\uB824
      \uC788\uB294 \uACF5\uAC04\uC5D0\uC11C \uC218\uB9CE\uC740 \uC0AC\uB78C\uC758
      \uC18C\uC74C\uC774 \uB108\uB97C \uC5D0\uC6CC\uC2F8\uACE0 \uC788\uC5B4. \uC774
      \uBCF5\uC7A1\uD55C \uD658\uACBD \uD55C\uAC00\uC6B4\uB370\uC5D0 \uC11C \uC788\uB294
      \uC9C0\uAE08, \uB124 \uBA38\uB9BF\uC18D\uC744 \uAC00\uC7A5 \uC138\uCC28\uAC8C
      \uB4A4\uD754\uB4E4\uACE0 \uC788\uB294 \uC0DD\uAC01\uC740 \uBB50\uC57C?"
    trigger: 0
    nextId: 8
    motionType: 0
    characterType: 6
    backgroundType: 5
    c1Label: 
    c1NextId: 
    c2Label: 
    c2NextId: 
    c3Label: 
    c3NextId: 
  - id: 8
    text: "\uC774\uB7F4 \uB550 \uC6B4\uB3D9\uC7A5 \uC804\uCCB4\uB97C \uBCF4\uB824\uACE0
      \uD558\uC9C0 \uB9C8. \uB208\uC744 \uC9C8\uB048 \uAC10\uC558\uB2E4\uAC00 \uB531
      3\uCD08\uB9CC \uB728\uACE0, \uB124 \uBC1C\uB05D\uC774 \uB51B\uACE0 \uC788\uB294
      \uC6B4\uB3D9\uC7A5\uC758 '\uD759'\uC774\uB098 \uC6B4\uB3D9\uC7A5\uC5D0 \uADF8\uB824\uC9C4
      '\uD770\uC0C9 \uB77C\uC778' \uD558\uB098\uC5D0\uB9CC \uC2DC\uC120\uC744 \uACE0\uC815\uD574
      \uBD10."
    trigger: 0
    nextId: 9
    motionType: 0
    characterType: 6
    backgroundType: 5
    c1Label: 
    c1NextId: 
    c2Label: 
    c2NextId: 
    c3Label: 
    c3NextId: 
  - id: 9
    text: "\uADF8\uB9AC\uACE0 \uC228\uC744 4\uCD08 \uB3D9\uC548 \uCC9C\uCC9C\uD788
      \uB4E4\uC774\uB9C8\uC2DC\uACE0, 4\uCD08 \uB3D9\uC548 \uB0B4\uC26C\uB294 \uAC70\uC57C.
      \uC8FC\uBCC0\uC758 \uC18C\uC74C\uC740 \uB2E4 \uBC30\uACBD\uC74C\uC545\uC77C
      \uBFD0\uC774\uC57C."
    trigger: 0
    nextId: 10
    motionType: 0
    characterType: 6
    backgroundType: 5
    c1Label: 
    c1NextId: 
