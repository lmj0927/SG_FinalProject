  - id: 65
    text: "\uD558\uD558\uD558! \uCE24\uB370\uB808 \uB140\uC11D. \uC218\uACE0\uD588\uB2E4!"
    trigger: 0
    nextId: 66
    motionType: 1
    characterType: 3
    backgroundType: 5
    c1Label: 
    c1NextId: 
    c2Label: 
    c2NextId: 
    c3Label: 
    c3NextId: 
  - id: 66
    text: "\uD558\uC9C4\uC774\uAC00 \uB0B4 \uBA38\uB9AC\uB97C \uC0AC\uC815\uC5C6\uC774
      \uD5DD\uD074\uC5B4\uD2B8\uB838\uB2E4."
    trigger: 0
    nextId: 67
    motionType: 0
    characterType: 7
    backgroundType: 5
    c1Label: 
    c1NextId: 
    c2Label: 
    c2NextId: 
    c3Label: 
    c3NextId: 
  - id: 67
    text: "\uC6B4\uB3D9\uC7A5 \uD55C\uD3B8\uC5D0 \uC11C\uC11C \uC544\uC774\uB4E4\uC758
      \uC6C3\uC74C\uC18C\uB9AC\uB97C \uB4E4\uC73C\uBA70, \uB098\uB294 \uC0DD\uAC01\uD588\uB2E4.
      \uC544\uC9C1\uB3C4 \uB0B4\uC77C\uC758 \uD559\uAD50\uB294 \uB450\uB835\uACE0,
      \uB0AF\uC120 \uC0AC\uB78C \uC55E\uC5D0 \uC11C\uBA74 \uBAA9\uC18C\uB9AC\uAC00
      \uB5A8\uB9AC\uB294 \uC99D\uC0C1\uC740 \uC5EC\uC804\uD560 \uAC83\uC774\uB2E4."
    trigger: 0
    nextId: 68
    motionType: 0
    characterType: 7
    backgroundType: 5
    c1Label: 
    c1NextId: 
    c2Label: 
    c2NextId: 
    c3Label: 
    c3NextId: 
  - id: 68
    text: "\uD558\uC9C0\uB9CC, \uC801\uC5B4\uB3C4 \uB0B4 \uB9C8\uC74C\uC744 \uC194\uC9C1\uD558\uAC8C
      \uC804\uB2EC\uD558\uACE0 \uD0C0\uD611\uD558\uB294 \uBC95\uC744, \uADF8\uB9AC\uACE0
      \uD0C0\uC778\uC758 \uB530\uB73B\uD55C \uC2DC\uC120\uC744 \uC628\uC804\uD788
      \uBC1B\uC544\uB4E4\uC774\uB294 \uBC95\uC744 \uC544\uC8FC \uC870\uAE08\uC740
      \uBC30\uC6B4 \uAC83 \uAC19\uB2E4\uACE0."
    trigger: 0
    nextId: 69
    motionType: 0
    characterType: 7
    backgroundType: 5
    c1Label: 
    c1NextId: 
    c2Label: 
    c2NextId: 
    c3Label: 
    c3NextId: 
  - id: 69
    text: "\uCCB4\uC721\uB300\uD68C\uC758 \uB728\uAC70\uC6E0\uB358 \uC5F4\uAE30\uAC00
      \uAC00\uB77C\uC549\uACE0, \uC6B4\uB3D9\uC7A5 \uC704\uB85C \uAE38\uAC8C \uB298\uC5B4\uC9C4
      \uB9CC\uAD6D\uAE30\uC758 \uADF8\uB9BC\uC790\uAC00 \uC11C\uC11C\uD788 \uBC88\uC838\uAC00\uAE30
      \uC2DC\uC791\uD588\uB2E4."
    trigger: 0
    nextId: 70
    motionType: 0
    characterType: 7
    backgroundType: 1
