    c2NextId: 
    c3Label: 
    c3NextId: 
  - id: 30
    text: "\uC544\uC774\uB4E4\uC774 \uC22B\uC790\uB97C \uC678\uCE58\uBA70 \uC77C\uC81C\uD788
      \uBC1C\uC744 \uAD6C\uB974\uB294 \uC18C\uB9AC\uC640 \uAD6C\uD638 \uC18C\uB9AC\uAC00
      \uD478\uB978 \uBD04 \uD558\uB298\uC744 \uCC0C\uB97C \uB4EF\uC774 \uC6B8\uB824
      \uD37C\uC84C\uB2E4."
    trigger: 0
