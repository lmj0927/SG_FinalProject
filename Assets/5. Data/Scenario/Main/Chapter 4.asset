    text: "\uD654\uBA74\uC5D0 \uB72C \uC774\uB984\uC740 \uB098\uB97C \uB610 \uB2E4\uB978
      \uC0C8\uB85C\uC6B4 \uACF3\uC73C\uB85C \uC774\uB04C\uACE0 \uC788\uC5C8\uB2E4."
