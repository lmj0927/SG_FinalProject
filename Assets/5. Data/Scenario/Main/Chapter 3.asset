    c1NextId: 
    c2Label: 
    c2NextId: 
    c3Label: 
    c3NextId: 
  - id: 20
    text: "\uB300\uC2E0 \uB0B4\uAC00 \uBC16\uC5D0\uC11C \uC904\uC744 \uB3CC\uB9AC\uB294
      \uC5ED\uD560\uC744 \uB9E1\uC73C\uBA74 \uC548 \uB420\uAE4C? \uD798\uC4F0\uACE0
      \uBC15\uC790 \uB9DE\uCD94\uB294 \uAC74 \uC815\uB9D0 \uC5F4\uC2EC\uD788 \uB178\uB825\uD574
      \uBCFC\uAC8C."
