    c1NextId: 
    c2Label: 
    c2NextId: 
    c3Label: 
    c3NextId: 
  - id: 2
    text: "\uBC18 \uC544\uC774\uB4E4\uC740 \uB2E8\uCCB4 \uC904\uB118\uAE30\uC640
      \uB9B4\uB808\uC774 \uACC4\uC8FC \uBA85\uB2E8\uC744 \uC9DC\uB290\uB77C \uBD84\uC8FC\uD588\uB2E4."
    trigger: 0
