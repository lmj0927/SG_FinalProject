    text: "\uB0B4\uC77C\uC774\uBA74 \uC800 \uB113\uC740 \uD759\uBC14\uB2E5\uC774
      \uC804\uAD50\uC0DD\uC758 \uD568\uC131\uACFC \uC2DC\uC120\uC73C\uB85C \uAC00\uB4DD
      \uCC30 \uAC83\uC774\uB2E4."
