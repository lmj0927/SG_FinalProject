    c3Label: 
    c3NextId: 
  - id: 29
    text: "\uC794\uC18C\uB9AC\uB294 \uBB34\uC2A8, \uB124\uAC00 \uC6A9\uAE30 \uB0B8
      \uAC70\uC9C0. \uC904 \uB3CC\uB9AC\uB294 \uAC70 \uC5F0\uC2B5 \uBE61\uC138\uAC8C
      \uD574\uC57C \uD55C\uB2E4? \uC544\uBB34\uB798\uB3C4 \uC6B0\uB9AC \uBC18\uC744
      \uB118\uACE0 \uC2F6\uB2E4\uBA74 \uB9D0\uC774\uC9C0!"
    trigger: 0
    nextId: 30
    motionType: 1
    characterType: 3
    backgroundType: 1
    c1Label: 
    c1NextId: 
    c2Label: 
    c2NextId: 
    c3Label: 
    c3NextId: 
  - id: 30
    text: "\uD558\uC9C4\uC774\uC758 \uC7A5\uB09C \uC11E\uC778 \uC751\uC6D0\uC744
      \uBC1B\uC73C\uBA70 \uB098\uB294 \uCC98\uC74C\uC73C\uB85C \uB2E4\uAC00\uC62C
      \uB2E8\uCCB4 \uD65C\uB3D9\uC774 '\uB450\uB835\uAE30\uB9CC \uD55C \uAC83'\uC740
      \uC544\uB2D0\uC9C0\uB3C4 \uBB38\uB4DD \uC0DD\uAC01\uD588\uB2E4."
    trigger: 0
    nextId: 31
    motionType: 0
    characterType: 7
    backgroundType: 1
    c1Label: 
    c1NextId: 
    c2Label: 
    c2NextId: 
    c3Label: 
    c3NextId: 
  - id: 31
    text: "\uADF8\uB0A0 \uC774\uD6C4, \uC810\uC2EC\uC2DC\uAC04\uB9C8\uB2E4 \uB2E8\uCCB4
      \uC904\uB118\uAE30 \uC5F0\uC2B5\uC774 \uC2DC\uC791\uB418\uC5C8\uB2E4."
    trigger: 0
    nextId: 32
    motionType: 0
    characterType: 7
    backgroundType: 5
    c1Label: 
    c1NextId: 
    c2Label: 
    c2NextId: 
    c3Label: 
    c3NextId: 
  - id: 32
    text: "\uB728\uAC70\uC6B4 \uD587\uBCD5 \uC544\uB798\uC5D0\uC11C \uBB34\uAC70\uC6B4
      \uBC27\uC904\uC744 \uC7A1\uC558\uC744 \uB54C, \uC190\uBC14\uB2E5\uC774 \uD654\uB048\uAC70\uB9AC\uACE0
      \uC628\uBAB8\uC758 \uADFC\uC721\uC774 \uAE34\uC7A5\uD588\uB2E4."
    trigger: 0
    nextId: 33
    motionType: 0
    characterType: 7
    backgroundType: 5
    c1Label: 
    c1NextId: 
    c2Label: 
    c2NextId: 
    c3Label: 
    c3NextId: 
  - id: 33
    text: "\uBC18\uB300\uD3B8\uC5D0\uC11C \uC904\uC744 \uC7A1\uC740 \uC544\uC774\uC640
      \uD0C0\uC774\uBC0D\uC774 \uB9DE\uC9C0 \uC54A\uC544 \uC904\uC774 \uAF2C\uC77C
      \uB54C\uB9C8\uB2E4 \uAC00\uC2B4\uC774 \uCCA0\uB801 \uB0B4\uB824\uC549\uC558\uC9C0\uB9CC,
      \uB098\uB294 \uC694\uC815\uC758 \uC870\uC5B8\uB300\uB85C \uC624\uC9C1 \uC544\uC774\uB4E4\uC758
      \uBC1C\uB05D\uACFC \uC904\uC774 \uBC14\uB2E5\uC5D0 \uB2FF\uB294 '\uD0C1, \uD0C1'
      \uC18C\uB9AC\uC5D0\uB9CC \uC628 \uC2E0\uACBD\uC744 \uC9D1\uC911\uD588\uB2E4."
    trigger: 0
    nextId: 34
    motionType: 0
    characterType: 7
    backgroundType: 5
    c1Label: 
    c1NextId: 
    c2Label: 
    c2NextId: 
    c3Label: 
    c3NextId: 
  - id: 34
    text: "\uCC2C\uC218\uC57C, \uBC29\uAE08 \uD0C0\uC774\uBC0D \uB531 \uC88B\uC558\uC5B4!
      \uADF8\uB300\uB85C\uB9CC \uB3CC\uB824\uC918!"
    trigger: 0
    nextId: 35
    motionType: 1
    characterType: 2
    backgroundType: 5
    c1Label: 
    c1NextId: 
    c2Label: 
    c2NextId: 
    c3Label: 
    c3NextId: 
  - id: 35
    text: "\uC904 \uC548\uC5D0\uC11C \uB6F0\uB358 \uC11C\uC5F0\uC774\uC758 \uACA9\uB824\uC5D0,
      \uB0B4 \uB450 \uD314\uC5D0\uB294 \uD55C\uCE35 \uB354 \uB2E8\uB2E8\uD55C \uD798\uC774
      \uB4E4\uC5B4\uAC14\uB2E4."
    trigger: 0
    nextId: 36
    motionType: 0
    characterType: 7
    backgroundType: 5
    c1Label: 
    c1NextId: 
    c2Label: 
    c2NextId: 
    c3Label: 
    c3NextId: 
  - id: 36
    text: "\uB0B4\uAC00 \uC774 \uC9D1\uB2E8\uC758 \uC18C\uC74C \uC18D\uC5D0 \uC11E\uC5EC
      \uBA85\uD655\uD55C \uD558\uB098\uC758 \uC8FC\uD30C\uC218\uB97C \uB0B4\uACE0
      \uC788\uB2E4\uB294 \uAC10\uAC01\uC774 \uC628\uBAB8\uC73C\uB85C \uC804\uD574\uC84C\uB2E4."
    trigger: 0
    nextId: 37
    motionType: 0
    characterType: 7
    backgroundType: 5
