  - id: 3
    text: "\uB098\uC5D0\uAC8C \uADF8\uB7F0 '\uB2E8\uCCB4 \uACBD\uAE30'\uB294 \uC218\uB9CE\uC740
      \uC0AC\uB78C\uC758 \uC2DC\uC120\uC774 \uC9D1\uC911\uB418\uB294, \uADF8\uC57C\uB9D0\uB85C
      \uC9C0\uC625\uC774\uB098 \uB2E4\uB984\uC5C6\uC5C8\uB2E4."
    trigger: 0
    nextId: 4
    motionType: 0
