  nodes:
  - id: 0
    text: "\uC2DC\uAC04\uC774 \uD758\uB7EC 5\uC6D4, \uD559\uAD50\uB294 \uD558\uC9C4\uC774\uC758
      \uB9D0\uB300\uB85C \uBD04 \uCCB4\uC721\uB300\uD68C \uC900\uBE44\uB85C \uB4E4\uC369\uC600\uB2E4."
