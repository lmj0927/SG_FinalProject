    c3NextId: 
  - id: 5
    text: "\uC6B0\uB9AC \uBC18 \uCCB4\uC721\uBD80\uC7A5 \uC8FC\uC11D\uC9C4\uC774
      \uBA85\uB2E8 \uD328\uB4DC\uB97C \uB4E4\uACE0 \uB0B4 \uC790\uB9AC\uB85C \uC654\uB2E4."
    trigger: 0
    nextId: 6
    motionType: 0
