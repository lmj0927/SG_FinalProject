    c1NextId: 
    c2Label: 
    c2NextId: 
    c3Label: 
    c3NextId: 
  - id: 37
    text: "\uC544\uC9C1 \uB0AF\uC120 \uC0AC\uB78C \uC55E\uC5D0\uC11C \uBAA9\uC18C\uB9AC\uAC00
      \uB5A8\uB9AC\uACE0 \uC2EC\uC7A5\uC774 \uB6F0\uB294 \uC7A5\uC560\uB294 \uC5EC\uC804\uD558\uB2E4.
      \uD558\uC9C0\uB9CC, \uC801\uC5B4\uB3C4 \uB0B4 \uB9C8\uC74C\uC744 \uC194\uC9C1\uD558\uAC8C
      \uC804\uB2EC\uD558\uACE0 \uD0C0\uD611\uD558\uB294 \uBC95\uC744 \uBC30\uC6E0\uB2E4."
    trigger: 0
    nextId: 38
    motionType: 0
    characterType: 7
    backgroundType: 5
