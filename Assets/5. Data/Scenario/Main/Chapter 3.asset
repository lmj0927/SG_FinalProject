  - id: 4
    text: "\uC57C, \uC9C0\uCC2C\uC218. \uB108\uB294 \uB2E8\uCCB4 \uC904\uB118\uAE30
      \uC778\uC6D0 \uBAA8\uC790\uB77C\uB2C8\uAE4C \uBB34\uC870\uAC74 \uAC19\uC774
      \uB6F0\uC5B4\uC57C \uD574."
    trigger: 0
    nextId: 5
    motionType: 0
    characterType: 0
    backgroundType: 1
    c1Label: 
    c1NextId: 
