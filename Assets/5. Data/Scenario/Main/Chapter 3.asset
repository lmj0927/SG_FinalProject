    c3NextId: 
  - id: 6
    text: "\uD0D5\uD0D5, \uC190\uAC00\uB77D\uC73C\uB85C \uD328\uB4DC\uB97C \uB450\uB4DC\uB9AC\uB294
      \uC18C\uB9AC\uAC00 \uAF2D \uB098\uB97C \uC555\uBC15\uD558\uB294 \uBC95\uC815\uC758
      \uC758\uC0AC\uBD09 \uC18C\uB9AC \uAC19\uC558\uB2E4."
    trigger: 0
    nextId: 7
