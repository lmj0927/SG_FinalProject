    c2Label: 
    c2NextId: 
    c3Label: 
    c3NextId: 
  - id: 11
    text: "\uBD80\uC815\uC801\uC778 \uCD5C\uC545\uC758 \uC2DC\uB098\uB9AC\uC624\uB4E4\uC774
      \uC21C\uC2DD\uAC04\uC5D0 \uBA38\uB9BF\uC18D\uC744 \uC9C0\uBC30\uD558\uBA70
      \uC2EC\uC7A5\uC774 \uAC00\uC058\uAC8C \uB6F0\uAE30 \uC2DC\uC791\uD588\uB2E4."
    trigger: 0
    nextId: 12
    motionType: 0
    characterType: 7
    backgroundType: 1
    c1Label: 
    c1NextId: 
    c2Label: 
    c2NextId: 
    c3Label: 
    c3NextId: 
  - id: 12
    text: "\uBAA9\uAD6C\uBA4D\uC774 \uBC14\uC9DD \uD0C0\uB4E4\uC5B4 \uAC00\uACE0,
      \uC11D\uC9C4\uC774\uC758 \uB2E8\uD638\uD55C \uB208\uBE5B\uC744 \uB9C8\uC8FC\uD558\uAE30\uAC00
      \uB108\uBB34\uB098 \uBC84\uAC70\uC6E0\uB2E4."
    trigger: 0
    nextId: 13
    motionType: 0
    characterType: 7
    backgroundType: 1
    c1Label: 
    c1NextId: 
    c2Label: 
    c2NextId: 
    c3Label: 
    c3NextId: 
  - id: 13
    text: "\uCC2C\uC218\uC57C, \uC11D\uC9C4\uC774\uAC00 \uB124 \uC774\uB984\uC744
      \uBA85\uB2E8\uC5D0 \uC801\uC73C\uBA70 \uBB34\uC870\uAC74 \uB2E8\uCCB4 \uC904\uB118\uAE30\uB97C
      \uAC19\uC774 \uB6F0\uC5B4\uC57C \uD55C\uB2E4\uACE0 \uB9D0\uD588\uC5B4. \uC8FC\uBCC0\uC758
      \uC2DC\uC120\uC774 \uB108\uC5D0\uAC8C \uC3E0\uB9B0 \uBC14\uB85C \uC9C0\uAE08,
      \uB124 \uBA38\uB9BF\uC18D\uC744 \uAC00\uC7A5 \uC138\uCC28\uAC8C \uB4A4\uD754\uB4E4\uACE0
      \uC788\uB294 \uC0DD\uAC01\uC740 \uBB50\uC57C?"
    trigger: 0
    nextId: 14
    motionType: 0
    characterType: 6
    backgroundType: 1
    c1Label: 
    c1NextId: 
    c2Label: 
    c2NextId: 
    c3Label: 
    c3NextId: 
  - id: 14
    text: "\uC798 \uC0DD\uAC01\uD574 \uBD10. \uC904\uB118\uAE30\uB97C \uD558\uB2E4\uAC00
      \uAC78\uB9AC\uB294 \uAC74 \uC544\uC8FC \uD754\uD55C \uC77C\uC774\uACE0, \uB2E4\uB978
      \uC560\uB4E4\uB3C4 \uC5F0\uC2B5\uD558\uBA74\uC11C \uC218\uC2ED \uBC88\uC740
      \uAC78\uB9B4 \uAC70\uC57C. \uBAA8\uB4E0 \uCC45\uC784\uC744 \uB124\uAC00 \uD63C\uC790
      \uC9CA\uC5B4\uC9C8 \uD544\uC694\uB294 \uC5C6\uC5B4."
    trigger: 0
    nextId: 15
    motionType: 0
    characterType: 6
    backgroundType: 1
    c1Label: 
    c1NextId: 
    c2Label: 
    c2NextId: 
    c3Label: 
    c3NextId: 
  - id: 15
    text: "\uADF8\uB9AC\uACE0 \uBB34\uC870\uAC74 '\uBABB \uD558\uACA0\uB2E4'\uACE0
      \uB3C4\uB9DD\uCE58\uAE30\uBCF4\uB2E4\uB294, \uB124\uAC00 \uAC10\uB2F9\uD560
      \uC218 \uC788\uB294 \uC120\uC5D0\uC11C \uC194\uC9C1\uD558\uAC8C \uC598\uAE30\uD558\uACE0
      \uB300\uC548\uC744 \uCC3E\uC544\uBCF4\uB294 \uAC74 \uC5B4\uB5A8\uAE4C?"
    trigger: 0
    nextId: 16
    motionType: 0
    characterType: 6
    backgroundType: 1
    c1Label: 
    c1NextId: 
    c2Label: 
    c2NextId: 
    c3Label: 
    c3NextId: 
  - id: 16
    text: "\uC904 \uC548\uC5D0 \uB4E4\uC5B4\uAC00\uC11C \uB6F0\uB294 \uAC8C \uB108\uBB34
      \uACF5\uD3EC\uC2A4\uB7FD\uB2E4\uBA74, \uCC28\uB77C\uB9AC \uBC16\uC5D0\uC11C
      \uB2E4\uB978 \uC5ED\uD560\uC744 \uC81C\uC548\uD574 \uBCF4\uB294 \uAC83\uB3C4
      \uBC29\uBC95\uC774\uC57C!"
    trigger: 0
    nextId: 17
    motionType: 0
    characterType: 6
    backgroundType: 1
    c1Label: 
    c1NextId: 
    c2Label: 
    c2NextId: 
    c3Label: 
    c3NextId: 
  - id: 17
    text: "\uB098\uB294 \uBB34\uB98E \uC704\uC5D0 \uC62C\uB824\uB454 \uB450 \uC190\uC744
      \uAF49 \uB9DE\uC7A1\uC558\uB2E4. \uC2EC\uC7A5\uC774 \uC694\uB3D9\uCCE4\uC9C0\uB9CC,
      \uC774\uBC88\uB9CC\uD07C\uC740 \uBB34\uC791\uC704\uB85C \uB3C4\uB9DD\uCE58\uAC70\uB098
      \uB545\uB9CC \uBCF4\uBA70 \uC5BC\uBC84\uBB34\uB9AC\uACE0 \uC2F6\uC9C0 \uC54A\uC558\uB2E4."
    trigger: 0
    nextId: 18
    motionType: 0
    characterType: 7
    backgroundType: 1
    c1Label: 
    c1NextId: 
    c2Label: 
    c2NextId: 
    c3Label: 
    c3NextId: 
  - id: 18
    text: "\uC694\uC815\uC758 \uB9D0\uB300\uB85C \uB0B4 \uBD88\uC548\uC744 \uC778\uC815\uD558\uB418,
      \uB0B4\uAC00 \uD560 \uC218 \uC788\uB294 \uCD5C\uC120\uC758 \uD0C0\uD611\uC810\uC744
      \uCC3E\uC544\uC57C \uD588\uB2E4. \uB098\uB294 \uCE68\uC744 \uD55C \uBC88 \uC0BC\uD0A4\uACE0
      \uC11D\uC9C4\uC774\uB97C \uBC14\uB77C\uBCF4\uC558\uB2E4."
    trigger: 0
    nextId: 19
    motionType: 0
    characterType: 7
    backgroundType: 1
    c1Label: 
    c1NextId: 
    c2Label: 
    c2NextId: 
    c3Label: 
    c3NextId: 
  - id: 19
    text: "\uC11D\uC9C4\uC544... \uB0B4\uAC00 \uC0AC\uC2E4 \uC6B4\uB3D9\uC2E0\uACBD\uC774
      \uB9CE\uC774 \uBD80\uC871\uD574\uC11C, \uAC19\uC774 \uB6F0\uBA74 \uC790\uAFB8
      \uC904\uC744 \uAC78\uB9AC\uAC8C \uD560\uAE4C \uBD10 \uAC71\uC815\uB3FC. \uBBFC\uD3D0
      \uB07C\uCE60\uAE4C \uBD10 \uBB34\uC11C\uC6B4\uB370..."
    trigger: 0
    nextId: 20
    motionType: 0
    characterType: 1
