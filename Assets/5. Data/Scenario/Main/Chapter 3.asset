  - id: 1
    text: "\uBCF5\uB3C4\uB97C \uC9C0\uB098\uAC08 \uB54C\uB9C8\uB2E4 \uAC01 \uBC18\uC758
      \uC751\uC6D0\uAC00 \uC5F0\uC2B5 \uC18C\uB9AC\uAC00 \uC6C5\uC6C5\uAC70\uB838\uACE0,
      \uC26C\uB294 \uC2DC\uAC04\uB9C8\uB2E4 \uC6B4\uB3D9\uC7A5\uC740 \uCD95\uAD6C\uC640
      \uD53C\uAD6C\uB97C \uC5F0\uC2B5\uD558\uB294 \uC544\uC774\uB4E4\uB85C \uBC1C
      \uB514\uB51C \uD2C8\uC774 \uC5C6\uC5C8\uB2E4."
    trigger: 0
    nextId: 2
    motionType: 0
    characterType: 7
    backgroundType: 1
