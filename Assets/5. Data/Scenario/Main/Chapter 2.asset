  - id: 2
    text: "(\uD558\uC9C4\uC774\uC758 \uC2A4\uD30C\uB974\uD0C0\uC2DD \uC794\uC18C\uB9AC
      \uB355\uBD84\uC5D0 \uC9DD\uAFCD \uC11C\uC5F0\uC774\uC640\uB294 \uC544\uCE68\uC5D0
      \uACA8\uC6B0 \"\uC548\uB155\"\uC774\uB77C\uB294 \uB2E8\uC5B4 \uC815\uB3C4\uB294
      \uC8FC\uACE0\uBC1B\uC744 \uC218 \uC788\uAC8C \uB418\uC5C8\uB2E4)"
    trigger: 0
    nextId: 3
    motionType: 0
