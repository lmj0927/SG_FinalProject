  - id: 63
    text: "\uB2E4\uB978 \uAC8C \uC544\uB2C8\uB77C, \uC544\uAE4C \uC11C\uC5F0\uC774\uAC00
      \uAD50\uBB34\uC2E4 \uB4E4\uB7EC\uC11C \uCC2C\uC218 \uB124\uAC00 \uAC00\uC0AC
      \uD574\uC11D \uCD08\uC548\uC744 \uC801\uADF9\uC801\uC73C\uB85C \uC9DC\uC624\uAE30\uB85C
      \uD588\uB2E4\uACE0 \uC5C4\uCCAD \uCE6D\uCC2C\uC744 \uD558\uB354\uB77C\uACE0.
      \uCC2C\uC218\uAC00 \uD31D\uC1A1\uC774\uB098 \uC601\uC5B4\uC5D0 \uAD00\uC2EC\uC774
      \uB9CE\uB2C8?"
    trigger: 0
    nextId: 64
    motionType: 1
    characterType: 5
    backgroundType: 4
    c1Label: 
    c1NextId: 
    c2Label: 
    c2NextId: 
    c3Label: 
    c3NextId: 
  - id: 64
    text: "\uC544... \uADF8, \uADF8\uAC8C... \uD31D\uC1A1 \uB4E3\uB294 \uAC78 \uC870\uAE08
      \uC88B\uC544\uD574\uC11C..."
