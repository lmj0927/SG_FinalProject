  nodes:
  - id: 0
    text: "4\uC6D4 \uC911\uC21C\uC758 1\uD559\uB144 1\uBC18 \uAD50\uC2E4\uC740 \uC911\uAC04\uACE0\uC0AC\uB97C
      \uC55E\uB450\uACE0 \uC218\uD589\uD3C9\uAC00\uC640 \uC870\uBCC4 \uACFC\uC81C
      \uACF5\uC9C0\uB85C \uC5B4\uC218\uC120\uD55C \uBD84\uC704\uAE30\uB2E4. \uCEF4\uD4E8\uD130\uC758
      \uC6C5\uC6C5\uAC70\uB9AC\uB294 \uC18C\uB9AC\uC640 \uC544\uC774\uB4E4\uC758
      \uC7A1\uB2F4\uC774 \uC11E\uC5EC\uC11C \uB4E4\uB824\uC624\uB294 \uAD50\uC2E4\uC774\uC5C8\uB2E4."
