  - id: 4
    text: "5\uAD50\uC2DC \uC601\uC5B4 \uC2DC\uAC04, \uC218\uD589\uD3C9\uAC00\uB85C
      2\uC778 1\uC870 \uD31D\uC1A1 \uAC00\uC0AC \uD574\uC11D \uBC0F \uBC1C\uD45C
      \uACFC\uC81C\uAC00 \uB5A8\uC5B4\uC84C\uB2E4."
    trigger: 0
    nextId: 5
    motionType: 0
