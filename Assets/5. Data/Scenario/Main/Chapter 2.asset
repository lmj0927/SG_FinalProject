  - id: 29
    text: "\uC9C4\uC9DC \uC6C3\uAE30\uB124. \uD750\uD750. \uC11C\uC5F0\uC544, \uC598\uAC00
      \uAF3C\uAF3C\uD558\uAC8C \uC798\uD558\uAE34 \uD558\uB294\uB370 \uD639\uC2DC\uB77C\uB3C4
      \uC798 \uBABB\uD558\uBA74 \uBC14\uB85C \uB9D0\uD574!"
    trigger: 0
    nextId: 30
