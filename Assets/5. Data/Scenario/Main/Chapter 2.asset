    c2NextId: 
    c3Label: 
    c3NextId: 
  - id: 3
    text: "(\uD558\uC9C0\uB9CC \uC5EC\uC804\uD788 \uB098\uC5D0\uAC8C \uAD50\uC2E4\uC740
      \uB108\uBB34 \uB9CE\uC740 \uC8FC\uD30C\uC218\uAC00 \uC5BD\uD600 \uC788\uB294
      \uBCF5\uC7A1\uD55C \uB77C\uB514\uC624 \uAC19\uB2E4. \uC870\uAE08\uB9CC \uBC29\uC2EC\uD574\uB3C4
      \uD0C0\uC778\uC758 \uC2DC\uC120\uC774\uB77C\uB294 \uB178\uC774\uC988\uAC00
      \uB0B4 \uBA38\uB9BF\uC18D\uC744 \uAC00\uB4DD \uCC44\uC6CC\uBC84\uB9B0\uB2E4)"
    trigger: 0
