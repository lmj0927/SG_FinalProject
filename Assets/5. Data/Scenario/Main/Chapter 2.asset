    c3NextId: 
  - id: 5
    text: "\uB2F4\uC784 \uC120\uC0DD\uB2D8\uC758 \uC870\uB840 \uB54C\uC640\uB294
      \uBE44\uAD50\uB3C4 \uC548 \uB420 \uB9CC\uD07C \uAD50\uC2E4\uC774 \uB4E4\uC369\uC600\uB2E4.
      \uCE5C\uD55C \uC560\uB4E4\uB07C\uB9AC \uB208\uBE5B\uC744 \uAD50\uD658\uD558\uBA70
      \uC21C\uC2DD\uAC04\uC5D0 \uC870\uB97C \uC9DC\uAE30 \uC2DC\uC791\uD588\uB2E4."
    trigger: 0
    nextId: 6
    motionType: 0
    characterType: 7
    backgroundType: 1
    c1Label: 
    c1NextId: 
    c2Label: 
    c2NextId: 
    c3Label: 
    c3NextId: 
  - id: 6
    text: "\uCC2C\uC218\uC57C, \uC120\uC0DD\uB2D8\uC758 \uB9D0\uC774 \uB5A8\uC5B4\uC9C0\uC790\uB9C8\uC790
      \uC544\uC774\uB4E4\uC774 \uC77C\uC81C\uD788 \uC6C0\uC9C1\uC774\uBA70 \uC870\uB97C
      \uC9DC\uAE30 \uC2DC\uC791\uD588\uC5B4. \uC9C0\uAE08 \uC774 \uC0C1\uD669\uC744
      \uBCF4\uBA74\uC11C \uB124 \uBA38\uB9BF\uC18D\uC5D0\uB294 \uC5B4\uB5A4 \uC0DD\uAC01\uC774
      \uC2A4\uCCD0 \uC9C0\uB098\uAC00\uACE0, \uADF8 \uC0DD\uAC01\uC5D0 \uB530\uB77C
      \uB108\uB294 \uC5B4\uB5BB\uAC8C \uD589\uB3D9\uD558\uB824\uACE0 \uD574?"
    trigger: 3
    nextId: 7
    motionType: 0
    characterType: 6
    backgroundType: 1
    c1Label: 
    c1NextId: 
    c2Label: 
    c2NextId: 
    c3Label: 
    c3NextId: 
  - id: 7
    text: "\uC774\uB7F4 \uB550 \uB108\uBB34 \uC870\uAE09\uD558\uAC8C \uC8FC\uC704\uB97C
      \uB450\uB9AC\uBC88\uAC70\uB9AC\uC9C0 \uB9C8. \uC624\uD788\uB824 \uADF8 \uB208\uBE5B\uC774
      \uBD88\uC548\uD574 \uBCF4\uC77C \uC218 \uC788\uAC70\uB4E0."
    trigger: 0
    nextId: 8
    motionType: 0
    characterType: 6
    backgroundType: 1
    c1Label: 
    c1NextId: 
    c2Label: 
    c2NextId: 
    c3Label: 
    c3NextId: 
  - id: 8
    text: "\uC77C\uB2E8 \uB124 \uCC45\uC0C1 \uC704 \uAD50\uC7AC\uB97C \uC815\uB9AC\uD558\uBA74\uC11C
      \uC228\uC744 \uD06C\uAC8C \uC138 \uBC88\uB9CC \uC26C\uC5B4\uBD10. \uB9CC\uC57D
      \uB05D\uAE4C\uC9C0 \uC870\uB97C \uBABB \uC9DC\uB354\uB77C\uB3C4 \uC120\uC0DD\uB2D8\uC774
      \uACB0\uAD6D \uB9DE\uCDB0\uC8FC\uC2E4 \uD14C\uB2C8\uAE4C '\uB099\uC624\uC790\uAC00
      \uB420 \uAC70\uB2E4'\uB77C\uB294 \uAC71\uC815\uC740 \uBBF8\uB9AC \uC0AC\uC11C
      \uD558\uC9C0 \uB9D0\uC790."
    trigger: 0
    nextId: 9
    motionType: 0
    characterType: 6
    backgroundType: 1
