  - id: 65
    text: "\uADF8\uB807\uAD6C\uB098. \uC11C\uC5F0\uC774\uAC00 \uD53C\uD53C\uD2F0\uB97C
      \uC798 \uB9CC\uB4DC\uB2C8\uAE4C, \uC774\uBC88 \uBC1C\uD45C \uB54C \uCC2C\uC218\uAC00
      \uD0A4\uC6CC\uB4DC \uC911\uC2EC\uC73C\uB85C \uBA87 \uBB38\uC7A5\uB9CC \uC18C\uAC1C\uD574
      \uC8FC\uBA74 \uB450 \uC0AC\uB78C \uB2E4 \uC544\uC8FC \uC88B\uC740 \uC810\uC218\uB97C
      \uBC1B\uC744 \uC218 \uC788\uC744 \uAC83 \uAC19\uC544\uC11C \uBBF8\uB9AC \uD301\uC744
      \uC8FC\uB824\uACE0 \uBD88\uB800\uC5B4. \uCC2C\uC218\uAC00 \uC870\uAE08\uB9CC
      \uC6A9\uAE30 \uB0B4\uC8FC\uBA74 \uBA4B\uC9C4 \uBC1C\uD45C\uAC00 \uB420 \uAC70\uC57C."
    trigger: 0
    nextId: 66
    motionType: 1
    characterType: 5
    backgroundType: 4
    c1Label: 
    c1NextId: 
    c2Label: 
    c2NextId: 
    c3Label: 
    c3NextId: 
  - id: 66
    text: "...\uB124. \uACFC, \uACFC\uC81C... \uC5F4\uC2EC\uD788 \uC900\uBE44\uD574
      \uAC08\uAC8C\uC694. \uAC10\uC0AC\uD569\uB2C8\uB2E4, \uC120\uC0DD\uB2D8."
