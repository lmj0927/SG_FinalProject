    c3NextId: 
  - id: 9
    text: "\uCC2C\uC218\uC57C! \uC6B0\uB9AC \uC601\uC5B4 \uC218\uD589\uD3C9\uAC00
      \uAC19\uC774 \uD560\uB798?"
