  nodes:
  - id: 0
    text: "\uC26C\uB294 \uC2DC\uAC04\uC774 \uC2DC\uC791\uB41C \uC9C0 \uBA87 \uBD84\uC774
      \uD758\uB800\uC744\uAE4C. \uAD50\uC2E4 \uC548\uC740 \uC5EC\uC804\uD788 \uC800\uB9C8\uB2E4
      \uBB34\uB9AC\uB97C \uC9C0\uC5B4 \uB5A0\uB4DC\uB294 \uC544\uC774\uB4E4\uC758
      \uC641\uC790\uC9C0\uAEC4\uD55C \uC18C\uC74C\uC73C\uB85C \uAC00\uB4DD\uD588\uB2E4."
