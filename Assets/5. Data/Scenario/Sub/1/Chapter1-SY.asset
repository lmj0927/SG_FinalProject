  - id: 15
    text: "(\uB0B4 \uB208\uC55E\uC5D0 \uB5A8\uC5B4\uC9C4 \uD39C\uB4E4\uC5D0\uB9CC
      \uC2DC\uC120\uC744 \uC881\uC774\uC790. \uB0B4\uAC00 \uD560 \uC218 \uC788\uB294
      \uBC29\uC2DD\uC744 \uACE0\uB974\uB294 \uAC70\uC57C.)"
    trigger: 1
    nextId: 
    motionType: 0
    characterType: 1
    backgroundType: 1
    c1Label: "\uC11C\uC5F0\uC774\uAC00 \uBBFC\uB9DD\uD558\uC9C0 \uC54A\uAC8C \"\uAD1C\uCC2E\uC544\"\uB77C\uACE0
      \uC791\uAC8C \uC74A\uC870\uB9AC\uBA70 \uBE60\uB974\uAC8C \uD39C\uC744 \uC90D\uB294\uB2E4."
    c1NextId: 16
    c2Label: "\uC190\uC774 \uB108\uBB34 \uB5A8\uB824 \uC120\uB73B \uC90D\uC9C0 \uBABB\uD558\uACE0,
      \uC11C\uC5F0\uC774\uAC00 \uAC74\uB124\uC8FC\uB294 \uD39C\uC744 \uC870\uC2EC\uD788
      \uBC1B\uC544 \uB4E0\uB2E4."
    c2NextId: 23
    c3Label: "\uC11C\uC5F0\uC774\uC640 \uB3D9\uC120\uC774 \uACB9\uCE58\uC9C0 \uC54A\uAC8C
