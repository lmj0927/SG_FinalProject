    c3NextId: 
  - id: 7
    text: "\uAE5C\uC9DD \uB180\uB780 \uC11C\uC5F0\uC774\uAC00 \uD669\uAE09\uD788
      \uD5C8\uB9AC\uB97C \uC219\uC774\uBA70 \uBC14\uB2E5\uC73C\uB85C \uB0B4\uB824\uC549\uC558\uB2E4."
