    backgroundType: 7
    c1Label: 
    c1NextId: 
    c2Label: 
    c2NextId: 
    c3Label: 
    c3NextId: 
  - id: 45
    text: "1\uD559\uB144 1\uBC18 \uAD50\uC2E4. \uAD50\uC2E4\uC740 \uB0A8\uB140 \uC11E\uC5EC
      \uC549\uC544 \uC2DC\uB04C\uBC85\uC801\uD55C \uBD84\uC704\uAE30\uB2E4."
    trigger: 0
    nextId: 46
    motionType: 0
    characterType: 7
    backgroundType: 1
    c1Label: 
    c1NextId: 
    c2Label: 
    c2NextId: 
    c3Label: 
    c3NextId: 
  - id: 46
    text: "\uD558\uC9C4\uC774\uAC00 \uC790\uAE30 \uBC18\uC73C\uB85C \uAC00\uACE0
      \uB09C \uB4A4, \uB098\uB294 \uB4B7\uBB38 \uCABD \uCC3D\uAC00 \uAD6C\uC11D \uC790\uB9AC\uC5D0
      \uC870\uC6A9\uD788 \uBC15\uD600 \uC788\uC5C8\uB2E4. \uC8FC\uBCC0\uC758 \uD65C\uAE30\uCC2C
      \uC5D0\uB108\uC9C0\uAC00 \uB098\uC5D0\uAC8C\uB294 \uB3C4\uC800\uD788 \uAE70
      \uC218 \uC5C6\uB294 \uAC70\uB300\uD55C \uC555\uBC15\uAC10\uC774\uC790 \uD22C\uBA85\uD55C
      \uC720\uB9AC\uBCBD\uCC98\uB7FC \uB2E4\uAC00\uC654\uB2E4."
    trigger: 0
    nextId: 47
    motionType: 0
    characterType: 7
    backgroundType: 1
    c1Label: 
    c1NextId: 
    c2Label: 
    c2NextId: 
    c3Label: 
    c3NextId: 
  - id: 47
    text: "\uCC45\uC0C1 \uBAA8\uC11C\uB9AC\uB9CC \uB9CC\uC9C0\uC791\uAC70\uB9AC\uACE0
      \uC788\uC744 \uB54C\uC600\uB2E4."
    trigger: 0
    nextId: 48
