    c1NextId: 
    c2Label: 
    c2NextId: 
    c3Label: 
    c3NextId: 
  - id: 54
    text: "\uB300\uB2F5\uC774 \uBC14\uB85C \uC548 \uB098\uC62C \uB54C\uB294 \uADF8\uB0E5
      \uC11C\uC5F0\uC774\uB97C \uBCF4\uBA74\uC11C \uACE0\uAC1C\uB97C \uC0B4\uC9DD
      \uB044\uB355\uC774\uAC70\uB098, '\uC5B4... \uC74C...' \uD558\uBA74\uC11C \uC0DD\uAC01\uD558\uB294
      \uC18C\uB9AC\uB9CC \uB0B4\uC918. \uB0B4\uAC00 \uB300\uD654\uB97C \uC539\uB294
      \uAC8C \uC544\uB2C8\uB77C '\uC900\uBE44 \uC911'\uC774\uB77C\uB294 \uC2E0\uD638\uB9CC
      \uC918\uB3C4, \uC0C1\uB300\uBC29\uC740 \uAE30\uBD84 \uC88B\uAC8C \uAE30\uB2E4\uB824
      \uC904 \uD14C\uB2C8\uAE4C!"
    trigger: 0
    nextId: 55
    motionType: 0
    characterType: 6
    backgroundType: 1
    c1Label: 
    c1NextId: 
    c2Label: 
    c2NextId: 
    c3Label: 
    c3NextId: 
