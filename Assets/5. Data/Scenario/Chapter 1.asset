  - id: 6
    text: "\uB108\uBB34 \uC798\uD558\uB824\uACE0 \uC560\uC4F8 \uD544\uC694 \uC5C6\uC5B4.
      \uB098\uB791 \uAC19\uC774 \uB531 \uD55C \uAC78\uC74C\uB9CC \uAC00\uBCF4\uB294
      \uAC70\uC57C."
    trigger: 0
    nextId: 7
    motionType: 0
