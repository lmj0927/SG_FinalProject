  - id: 30
    text: "\uD558\uC9C4\uC774\uC758 \uC190\uC5D0 \uC774\uB04C\uB824 \uAC70\uB300\uD55C
      \uB300\uC790\uBCF4\uAC00 \uBD99\uC740 \uAC8C\uC2DC\uD310 \uC55E\uC73C\uB85C
      \uD5A5\uD588\uB2E4. \uAE68\uC54C \uAC19\uC740 \uC774\uB984\uB4E4 \uC0AC\uC774\uB97C
      \uD6D1\uB358 \uD558\uC9C4\uC774\uAC00 \uAC11\uC790\uAE30 \uD06C\uAC8C \uD0C4\uC2DD\uC744
      \uB0B4\uBC49\uC5C8\uB2E4."
    trigger: 0
    nextId: 31
    motionType: 0
    characterType: 7
    backgroundType: 7
    c1Label: 
    c1NextId: 
    c2Label: 
    c2NextId: 
    c3Label: 
    c3NextId: 
  - id: 31
    text: "\uC544, \uAE4C\uBE44! \uB098 4\uBC18\uC778\uB370 \uB108 1\uBC18\uC774\uB124?
      \uC6B0\uB9AC\uAC00 \uAC08\uB77C\uC9C0\uB2E4\uB2C8!"
    trigger: 0
    nextId: 32
    motionType: 1
    characterType: 3
    backgroundType: 7
    c1Label: 
    c1NextId: 
    c2Label: 
    c2NextId: 
    c3Label: 
    c3NextId: 
  - id: 32
    text: "...\uC544."
    trigger: 0
    nextId: 33
    motionType: 0
    characterType: 1
    backgroundType: 7
    c1Label: 
    c1NextId: 
    c2Label: 
    c2NextId: 
    c3Label: 
    c3NextId: 
  - id: 33
    text: "\uAC00\uC7A5 \uB450\uB824\uC6CC\uD558\uB358 \uC0C1\uD669\uC774 \uC624\uC790
      \uB098\uB3C4 \uBAA8\uB974\uAC8C \uAC00\uC2B4\uC774 \uB35C\uCEE5 \uB0B4\uB824\uC549\uC558\uB2E4.
      \uD63C\uC790\uC11C \uAD50\uC2E4\uC5D0 \uB0A8\uC544\uC788\uC744 \uC0DD\uAC01\uC744
      \uD558\uB2C8 \uBC8C\uC368 \uB208\uC55E\uC774 \uC544\uB4DD\uD574\uC84C\uB2E4."
    trigger: 0
    nextId: 34
    motionType: 0
    characterType: 7
    backgroundType: 7
    c1Label: 
    c1NextId: 
    c2Label: 
    c2NextId: 
    c3Label: 
    c3NextId: 
  - id: 34
    text: "\uCC2C\uC218\uC57C, \uB298 \uB4E0\uB4E0\uD55C \uBC84\uD300\uBAA9\uC774
      \uB418\uC5B4\uC8FC\uB358 \uD558\uC9C4\uC774\uC640 \uBC18\uC774 \uB5A8\uC5B4\uC84C\uAD6C\uB098.
      \uCE5C\uD55C \uCE5C\uAD6C\uC640 \uB5A8\uC5B4\uC9C4 \uC21C\uAC04, \uB124 \uBA38\uB9BF\uC18D\uC744
      \uAC00\uC7A5 \uBA3C\uC800 \uB4E0 \uC0DD\uAC01\uC740 \uC5B4\uB5A4 \uAC70\uC57C?"
    trigger: 3
    nextId: 35
    motionType: 0
    characterType: 6
    backgroundType: 7
    c1Label: 
    c1NextId: 
    c2Label: 
    c2NextId: 
    c3Label: 
    c3NextId: 
  - id: 35
    text: "\uD558\uC9C0\uB9CC \uCC2C\uC218\uC57C, \uC6B0\uB9AC \uB0C9\uC815\uD558\uAC8C
      \uD329\uD2B8\uB9CC \uBCF4\uC790!"
    trigger: 0
    nextId: 36
    motionType: 0
    characterType: 6
    backgroundType: 7
    c1Label: 
    c1NextId: 
    c2Label: 
    c2NextId: 
    c3Label: 
    c3NextId: 
  - id: 36
    text: "\uD558\uC9C4\uC774 \uB9D0\uB300\uB85C \uB108\uD76C\uB294 \uC5EC\uC804\uD788
      \uAC19\uC740 \uCE35\uC774\uACE0 \uBCF5\uB3C4 \uB9E8 \uB05D\uACFC \uB05D\uC77C
      \uBFD0\uC774\uC57C."
    trigger: 0
    nextId: 37
    motionType: 0
    characterType: 6
    backgroundType: 7
    c1Label: 
    c1NextId: 
    c2Label: 
    c2NextId: 
    c3Label: 
    c3NextId: 
  - id: 37
    text: "\uCD5C\uC545\uC758 \uC0C1\uD669\uC744 \uC0C1\uC0C1\uD558\uAC8C \uB9CC\uB4DC\uB294
      '\uBD88\uC548 \uB80C\uC988'\uB294 \uC7A0\uC2DC \uBE7C\uB450\uACE0, '\uC5B8\uC81C\uB4E0
      \uBB38\uB9CC \uC5F4\uACE0 \uB098\uAC00\uBA74 \uD558\uC9C4\uC774\uB97C \uBCFC
      \uC218 \uC788\uB2E4'\uB294 \uC0AC\uC2E4\uB9CC \uC0DD\uAC01\uD558\uC790. \uAD50\uC2E4\uC774\uB77C\uB294
      \uBC29\uB9CC \uBC14\uB010 \uAC70\uC9C0, \uB108\uB97C \uC751\uC6D0\uD558\uB294
      \uBCA0\uD504\uAC00 \uC5B4\uB514 \uC0AC\uB77C\uC9C4 \uAC74 \uC544\uB2C8\uC796\uC544?"
    trigger: 0
    nextId: 38
    motionType: 0
    characterType: 6
    backgroundType: 7
    c1Label: 
    c1NextId: 
    c2Label: 
    c2NextId: 
    c3Label: 
    c3NextId: 
  - id: 38
    text: "\uB0B4 \uC5BC\uAD74\uC744 \uC0B4\uD53C\uB358 \uD558\uC9C4\uC774\uAC00
      \uC5BC\uB978 \uB0B4 \uC5B4\uAE68\uB97C \uAF49 \uC950\uBA70 \uB9D0\uC744 \uC774\uC5C8\uB2E4."
    trigger: 0
    nextId: 39
    motionType: 0
    characterType: 7
    backgroundType: 7
    c1Label: 
    c1NextId: 
    c2Label: 
    c2NextId: 
    c3Label: 
    c3NextId: 
  - id: 39
    text: "\uC57C\uC57C, \uADF8\uB798\uB3C4 \uAE30\uC6B4 \uBE7C\uC9C0 \uB9C8! \uC6B0\uB9AC
      \uCE35\uC740 \uAC19\uB2E4? \uBCF5\uB3C4 \uB9E8 \uB05D\uACFC \uB05D\uC774\uB124.
      \uB2EC\uB9AC\uAE30\uD558\uBA74 5\uCD08 \uCEF7\uC774\uC57C."
    trigger: 0
    nextId: 40
    motionType: 1
    characterType: 3
    backgroundType: 7
    c1Label: 
    c1NextId: 
    c2Label: 
    c2NextId: 
    c3Label: 
    c3NextId: 
  - id: 40
    text: "\uB2E4\uD589\uC774\uB2E4... \uCE35\uC774\uB77C\uB3C4 \uAC19\uC544\uC11C..."
    trigger: 0
    nextId: 41
    motionType: 0
    characterType: 1
    backgroundType: 7
    c1Label: 
    c1NextId: 
    c2Label: 
    c2NextId: 
    c3Label: 
    c3NextId: 
  - id: 41
    text: "\uB0B4\uAC00 \uC544\uCE68\uC5D0 \uC2AC\uCA4D \uCCB4\uD06C\uD574 \uBCF4\uB2C8\uAE4C,
      1\uBC18\uC5D0 \uC911\uD559\uAD50 \uB54C \uC21C\uB465\uC774\uB85C \uC18C\uBB38\uB09C
      \uC560\uB4E4 \uB9CE\uC774 \uBC30\uC815\uB410\uB354\uB77C\uACE0. \uCC29\uD55C
      \uC560\uB4E4 \uB9CE\uC544 \uBCF4\uC774\uB2C8\uAE4C \uB108\uBB34 \uAC81\uBA39\uC9C0
      \uB9C8."
    trigger: 0
    nextId: 42
    motionType: 1
    characterType: 3
    backgroundType: 7
    c1Label: 
    c1NextId: 
    c2Label: 
    c2NextId: 
    c3Label: 
    c3NextId: 
  - id: 42
    text: "\uC26C\uB294 \uC2DC\uAC04\uB9C8\uB2E4 \uB0B4\uAC00 1\uBC18\uC73C\uB85C
      \uC885 \uCE58\uC790\uB9C8\uC790 \uCD9C\uC11D \uB3C4\uC7A5 \uCC0D\uC744 \uD14C\uB2C8\uAE4C,
      \uAE30\uC8FD\uC5B4 \uC788\uC9C0 \uB9D0\uACE0 \uB531 \uB124 \uC790\uB9AC \uC9C0\uD0A4\uACE0
      \uC788\uC5B4\uB77C?"
    trigger: 0
    nextId: 43
    motionType: 1
    characterType: 3
    backgroundType: 7
    c1Label: 
    c1NextId: 
    c2Label: 
    c2NextId: 
    c3Label: 
    c3NextId: 
  - id: 43
    text: "\uAC00\uC790, \uC9C0\uCC2C\uC218!"
    trigger: 0
    nextId: 44
    motionType: 1
    characterType: 3
    backgroundType: 7
    c1Label: 
    c1NextId: 
    c2Label: 
    c2NextId: 
    c3Label: 
    c3NextId: 
  - id: 44
    text: "\uD558\uC9C4\uC774\uC758 \uB4E0\uB4E0\uD55C \uB4F1\uC9DD\uC744 \uBCF4\uBA70,
      \uB098\uB294 \uAC04\uC2E0\uD788 1\uBC18 \uAD50\uC2E4\uC744 \uD5A5\uD574 \uBC1C\uAC78\uC74C\uC744
      \uC62E\uACBC\uB2E4."
