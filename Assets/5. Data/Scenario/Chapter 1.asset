  - id: 19
    text: "\uC77C\uB2E8 \uC790\uB9AC\uC5D0 \uB531 \uBA48\uCDB0 \uC11C\uC11C, \uB124
      \uBC1C\uBC14\uB2E5\uC774 \uB545\uC744 \uAFB9 \uB204\uB974\uACE0 \uC788\uB294
      \uBB35\uC9C1\uD55C \uB290\uB08C\uC5D0\uB9CC \uC9D1\uC911\uD574 \uBD10."
    trigger: 0
    nextId: 20
    motionType: 0
    characterType: 6
    backgroundType: 7
    c1Label: 
    c1NextId: 
    c2Label: 
    c2NextId: 
    c3Label: 
    c3NextId: 
  - id: 20
    text: "\uADF8\uB9AC\uACE0 \uB208\uC5D0 \uBCF4\uC774\uB294 \uCD08\uB85D\uC0C9
      \uBB3C\uAC74 3\uAC1C\uB098 \uAD50\uBB38 \uAC04\uD310 \uAE00\uC528 \uAC19\uC740
      \uAC70 \uD558\uB098\uB9CC \uACE8\uB77C\uC11C \uBE64\uD788 \uCCD0\uB2E4\uBCF4\uB294
      \uAC70\uC57C. \uC6C5\uC131\uAC70\uB9AC\uB294 \uC0AC\uB78C\uB4E4\uC5D0\uAC8C\uC11C
      \uC2DC\uC120\uC744 \uC2AC\uCA4D \uB3CC\uB9AC\uB294 \uAC83\uB9CC\uC73C\uB85C\uB3C4
      \uCFF5\uCF85\uAC70\uB9AC\uB294 \uC2EC\uC7A5\uC774 \uD6E8\uC52C \uCC28\uBD84\uD574\uC9C8\uAC78?"
    trigger: 0
    nextId: 21
    motionType: 0
    characterType: 6
    backgroundType: 7
    c1Label: 
    c1NextId: 
    c2Label: 
    c2NextId: 
    c3Label: 
    c3NextId: 
  - id: 21
    text: "\uAD50\uBB38 \uC55E \uAC00\uB85C\uC218 \uBC11, \uC218\uB9CE\uC740 \uC778\uD30C
      \uC18D\uC5D0\uC11C \uD640\uB85C \uC12C\uCC98\uB7FC \uACE0\uB9BD\uB418\uC5B4
      \uBC14\uB2E5\uB9CC \uB6AB\uC5B4\uC838\uB77C \uBCF4\uACE0 \uC788\uC744 \uB54C\uC600\uB2E4.
      \uAC11\uC790\uAE30 \uB4F1 \uB4A4\uC5D0\uC11C \uC775\uC219\uD558\uACE0 \uAC70\uCE5C
      \uC190\uAE38\uC774 \uB0B4 \uBAA9\uC744 \uB365\uC11D \uAC10\uC2F8 \uC548\uC558\uB2E4."
    trigger: 0
    nextId: 22
    motionType: 0
    characterType: 7
    backgroundType: 7
    c1Label: 
    c1NextId: 
    c2Label: 
    c2NextId: 
    c3Label: 
    c3NextId: 
  - id: 22
    text: "\uC57C, \uC9C0\uCC2C\uC218! \uB108 \uC5EC\uAE30\uC11C \uB4F1\uAD50 \uAC70\uBD80
      \uC2DC\uC704\uD558\uB0D0?"
    trigger: 0
    nextId: 23
