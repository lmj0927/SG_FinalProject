      \uC6B8\uB9AC\uC790 \uD558\uC9C4\uC774\uB294 \u201C\uC774\uB530 \uC26C\uB294
      \uC2DC\uAC04\uC5D0 \uB610 \uC62C\uAC8C!\u201D\uB77C\uBA70 4\uBC18\uC73C\uB85C
