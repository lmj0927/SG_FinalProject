    c3Label: 
    c3NextId: 
  - id: 59
    text: "\uCE5C\uADFC\uD558\uAC8C \uC6C3\uC5B4\uC8FC\uB294 \uC11C\uC5F0\uC774\uC758
      \uBAA8\uC2B5\uC5D0 \uC2EC\uC7A5\uC758 \uD3ED\uC8FC\uAC00 \uC870\uAE08\uC740
      \uAC00\uB77C\uC549\uB294 \uB290\uB08C\uC774\uC5C8\uB2E4. \uADF8\uB54C \uC55E
      \uBB38\uC5D0\uC11C \uD558\uC9C4\uC774\uAC00 \uB300\uACAC\uD558\uB2E4\uB294
      \uB208\uBE5B\uC73C\uB85C \uAC78\uC5B4 \uB4E4\uC5B4\uC654\uB2E4."
