    c3Label: 
    c3NextId: 
  - id: 48
    text: "\uC548\uB155? \uC9DD\uAFCD\uC774\uB124! \uB09C \uC774\uC11C\uC5F0\uC774\uC57C.
      \uB10C \uC774\uB984\uC774 \uBB50\uC57C?"
    trigger: 0
    nextId: 49
    motionType: 1
    characterType: 2
    backgroundType: 1
    c1Label: 
    c1NextId: 
    c2Label: 
    c2NextId: 
    c3Label: 
    c3NextId: 
  - id: 49
    text: "\uC55E\uC790\uB9AC\uC5D0 \uC549\uC740 \uC7A5\uBC1C\uBA38\uB9AC\uC758 \uC5EC\uD559\uC0DD\uC774
      \uC6C3\uC73C\uBA70 \uB4A4\uB97C \uB3CC\uC544\uBD24\uB2E4. \uC21C\uAC04 \uBA38\uB9BF\uC18D\uC774
      \uC0C8\uD558\uC597\uAC8C \uD0C8\uC0C9\uB418\uB294 \uAC83 \uAC19\uC558\uB2E4."
    trigger: 0
    nextId: 50
    motionType: 0
    characterType: 7
    backgroundType: 1
    c1Label: 
    c1NextId: 
    c2Label: 
    c2NextId: 
    c3Label: 
    c3NextId: 
  - id: 50
    text: "\uC2DC\uC120\uC744 \uC5B4\uB514\uC5D0 \uB450\uC5B4\uC57C \uD560\uC9C0
      \uBAB0\uB77C \uB3D9\uACF5\uC774 \uC0AC\uC815\uC5C6\uC774 \uD754\uB4E4\uB838\uACE0,
      \uBAA9\uAD6C\uBA4D\uC5D0 \uCEE4\uB2E4\uB780 \uB3CC\uB369\uC774\uAC00 \uAC78\uB9B0
      \uAC83\uCC98\uB7FC \uC18C\uB9AC\uAC00 \uB098\uC624\uC9C0 \uC54A\uC558\uB2E4."
    trigger: 0
    nextId: 51
    motionType: 0
    characterType: 7
    backgroundType: 1
    c1Label: 
    c1NextId: 
    c2Label: 
    c2NextId: 
    c3Label: 
    c3NextId: 
  - id: 51
    text: "\uC11C\uC5F0\uC774\uAC00 \uB300\uB2F5\uC744 \uAE30\uB2E4\uB9AC\uBA70 \uACE0\uAC1C\uB97C
      \uAE4C\uB531\uC774\uC790, \uC8FC\uBCC0\uC758 \uBA87\uBA87 \uC544\uC774\uB4E4\uB3C4
      \uB0B4 \uC5B4\uC0C9\uD55C \uCE68\uBB35\uC5D0 \uAD00\uC2EC\uC744 \uAC00\uC9C0\uBA70
      \uC2DC\uC120\uC744 \uC8FC\uAE30 \uC2DC\uC791\uD588\uB2E4. \uADC0\uAC00 \uBA39\uBA39\uD574\uC9C8
      \uC815\uB3C4\uB85C \uC2EC\uC7A5 \uC18C\uB9AC\uAC00 \uD06C\uAC8C \uC6B8\uB838\uB2E4."
    trigger: 0
    nextId: 52
    motionType: 0
    characterType: 7
    backgroundType: 1
    c1Label: 
    c1NextId: 
    c2Label: 
    c2NextId: 
    c3Label: 
    c3NextId: 
  - id: 52
    text: "\uCC2C\uC218\uC57C, \uC11C\uC5F0\uC774\uC758 \uC9C8\uBB38\uACFC \uC544\uC774\uB4E4\uC758
      \uC2DC\uC120\uC774 \uB124\uAC8C \uC3DF\uC544\uC84C\uC744 \uB54C, \uB124 \uCE68\uBB35\uC774
      \uAE38\uC5B4\uC9C8\uC218\uB85D \uC8FC\uC704 \uC0AC\uB78C\uB4E4\uC774 \uB108\uB97C
      \uC5B4\uB5BB\uAC8C \uD310\uB2E8\uD560\uAE4C \uBD10 \uB450\uB824\uC6B4 \uAC70\uB2C8?"
    trigger: 3
    nextId: 53
    motionType: 0
    characterType: 6
    backgroundType: 1
    c1Label: 
    c1NextId: 
    c2Label: 
    c2NextId: 
    c3Label: 
    c3NextId: 
  - id: 53
    text: "\uCC2C\uC218\uC57C, \uB300\uD654\uD560 \uB54C \uC544\uB098\uC6B4\uC11C\uCC98\uB7FC
      \uC5C4\uCCAD \uC720\uCC3D\uD558\uACE0 \uBE60\uB974\uAC8C \uB9D0 \uC548 \uD574\uB3C4
      \uB3FC! \uBAA9\uC18C\uB9AC\uAC00 \uC880 \uC791\uC544\uB3C4, \uBC84\uBC85\uAC70\uB824\uB3C4
      \uB2E4 \uAD1C\uCC2E\uC544."
    trigger: 0
    nextId: 54
    motionType: 0
    characterType: 6
    backgroundType: 1
