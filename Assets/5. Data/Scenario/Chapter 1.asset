    c3NextId: 
  - id: 16
    text: "(\uBC1C\uBC14\uB2E5\uC774 \uCF58\uD06C\uB9AC\uD2B8 \uBC14\uB2E5\uC5D0
      \uBD99\uC5B4\uBC84\uB9B0 \uAC83\uCC98\uB7FC, \uD55C \uAC78\uC74C\uB3C4 \uBABB
      \uC6C0\uC9C1\uC774\uACA0\uC5B4\u2026\u2026)"
