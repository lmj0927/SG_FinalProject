  nodes:
  - id: 0
    text: "\uC548\uB155! \uB4DC\uB514\uC5B4 \uB9CC\uB0AC\uB124? \uB09C \uC55E\uC73C\uB85C
      \uB124 \uC606\uC5D0 \uCC30\uB5A1\uCC98\uB7FC \uBD99\uC5B4 \uB2E4\uB2D0 \uC694\uC815\uC774\uC57C."
