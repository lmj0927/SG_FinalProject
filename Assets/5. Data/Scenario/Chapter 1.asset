    c1NextId: 
    c2Label: 
    c2NextId: 
    c3Label: 
    c3NextId: 
  - id: 1
    text: "\uB9C9 \uC8FC\uBCC0\uC774 \uB108\uBB34 \uC2DC\uB044\uB7FD\uACE0, \uC0AC\uB78C\uB4E4\uC774
      \uB2E4 \uB098\uB9CC \uCCD0\uB2E4\uBCF4\uB294 \uAC83 \uAC19\uC544\uC11C \uC228\uC774
      \uD131 \uB9C9\uD790 \uB54C \uC788\uC9C0?"
    trigger: 0
    nextId: 2
    motionType: 0
    characterType: 6
    backgroundType: 6
    c1Label: 
    c1NextId: 
    c2Label: 
    c2NextId: 
    c3Label: 
    c3NextId: 
  - id: 2
    text: "\uADF8\uAC70 \uB124\uAC00 \uC774\uC0C1\uD574\uC11C \uADF8\uB7F0 \uAC70
      \uC808\uB300 \uC544\uB2C8\uB2E4? \uADF8\uB0E5 \uB124 \uB9C8\uC74C\uC18D \uBC29\uC5B4\uBCBD\uC774
      \uB0A8\uB4E4\uBCF4\uB2E4 \uCABC~\uAE08 \uB354 \uC131\uC2E4\uD558\uACE0 \uB208\uCE58\uAC00
      \uBE68\uB77C\uC11C \uADF8\uB7F0 \uAC83\uBFD0\uC774\uC57C."
    trigger: 0
    nextId: 3
    motionType: 0
    characterType: 6
    backgroundType: 6
    c1Label: 
    c1NextId: 
    c2Label: 
    c2NextId: 
    c3Label: 
    c3NextId: 
  - id: 3
    text: "\uC55E\uC73C\uB85C \uB124\uAC00 \uC0C8\uB85C\uC6B4 \uC138\uC0C1\uC73C\uB85C
      \uD55C \uAC78\uC74C\uC529 \uB098\uC544\uAC08 \uB54C\uB9C8\uB2E4, \uB0B4\uAC00
      \uB531 \uBD99\uC5B4\uC11C \uB124 \uD3B8 \uB4E4\uC5B4\uC904\uAC8C."
    trigger: 0
    nextId: 4
    motionType: 0
    characterType: 6
    backgroundType: 6
    c1Label: 
    c1NextId: 
    c2Label: 
    c2NextId: 
    c3Label: 
    c3NextId: 
  - id: 4
    text: "\uB9C8\uC74C\uC774 \uAF41\uAF41 \uC5BC\uC5B4\uBD99\uAC70\uB098 \uB3C4\uB9DD\uCE58\uACE0
      \uC2F6\uC744 \uB550 \uC5B8\uC81C\uB4E0 \uB098\uB97C \uBD88\uB7EC!"
    trigger: 0
    nextId: 5
    motionType: 0
