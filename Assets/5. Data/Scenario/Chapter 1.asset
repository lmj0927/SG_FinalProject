    backgroundType: 6
    c1Label: 
    c1NextId: 
    c2Label: 
    c2NextId: 
    c3Label: 
    c3NextId: 
  - id: 7
    text: "\uBB38\uC744 \uC5F4\uBA74 \uBC9A\uAF43\uC774 \uC5C4\uCCAD \uC608\uC058\uAC8C
      \uB0A0\uB9AC\uB294 \uB4F1\uAD50\uAE38\uC774 \uD3BC\uCCD0\uC9C8 \uAC70\uC57C.
      \uAC00\uC790!"
    trigger: 0
    nextId: 8
    motionType: 0
    characterType: 6
    backgroundType: 6
    c1Label: 
    c1NextId: 
    c2Label: 
    c2NextId: 
    c3Label: 
    c3NextId: 
  - id: 8
    text: "\uBC9A\uAF43\uC774 \uB9CC\uAC1C\uD55C \uB4F1\uAD50\uAE38. \uAD50\uBB38
      \uC55E\uC740 \uC2E0\uC785\uC0DD\uB4E4\uACFC \uD559\uBD80\uBAA8\uB4E4\uB85C
      \uC778\uC0B0\uC778\uD574\uB2E4."
    trigger: 0
    nextId: 9
    motionType: 0
    characterType: 7
    backgroundType: 7
    c1Label: 
    c1NextId: 
    c2Label: 
    c2NextId: 
    c3Label: 
    c3NextId: 
  - id: 9
    text: "(\uB0A8\uB140\uACF5\uD559 \uACE0\uB4F1\uD559\uAD50\uB77C\uB2C8, \uB0B4
      \uC778\uC0DD \uCD5C\uB300\uC758 \uBB34\uB9AC\uC218\uB2E4.)"
    trigger: 0
    nextId: 10
    motionType: 0
    characterType: 1
    backgroundType: 7
    c1Label: 
    c1NextId: 
    c2Label: 
    c2NextId: 
    c3Label: 
    c3NextId: 
  - id: 10
    text: "(\uC8FC\uBCC0\uC5D0\uC11C \uB4E4\uB824\uC624\uB294 \uC800 \uD558\uC774\uD1A4\uC758
      \uC6C3\uC74C\uC18C\uB9AC, \uB0AE\uAC8C \uC6C5\uC131\uAC70\uB9AC\uB294 \uB300\uD654\uB4E4,
      \uC2A4\uCCD0 \uC9C0\uB098\uAC00\uB294 \uD559\uC0DD\uB4E4\uC758 \uB0AF\uC120
      \uAD50\uBCF5 \uAE43... \uBAA8\uB4E0 \uAC8C \uB098\uB97C \uC555\uBC15\uD558\uB294
      \uAC70\uB300\uD55C \uBCBD\uCC98\uB7FC \uB290\uAEF4\uC9C4\uB2E4.)"
    trigger: 0
    nextId: 11
    motionType: 0
    characterType: 1
    backgroundType: 7
    c1Label: 
    c1NextId: 
    c2Label: 
    c2NextId: 
    c3Label: 
    c3NextId: 
  - id: 11
    text: "(\uC560\uB4E4\uC774 \uB098\uD55C\uD14C \uAC11\uC790\uAE30 \uB9D0\uC744
      \uAC78\uBA74 \uC5B4\uCA4C\uC9C0?)"
