  - id: 17
    text: "\uCC2C\uC218\uC57C, \uC774\uB807\uAC8C \uC218\uB9CE\uC740 \uC0AC\uB78C
      \uC55E\uC5D0 \uAC11\uC790\uAE30 \uB178\uCD9C\uB418\uAC70\uB098 \uC8FC\uBAA9\uBC1B\uC544\uC57C
      \uD558\uB294 \uC0C1\uD669\uC774 \uC624\uBA74, \uAD6C\uCCB4\uC801\uC73C\uB85C
      \uC5B4\uB5A4 \uBD80\uBD84\uC774 \uAC00\uC7A5 \uB450\uB835\uAC8C \uB290\uAEF4\uC838?"
    trigger: 3
    nextId: 97
    motionType: 0
    characterType: 6
    backgroundType: 7
    situation: "\uAD6D\uC5B4 \uC2DC\uAC04.\n\uCE5C\uAD6C\uB4E4 \uC55E\uC5D0\uC11C 3\uBD84 \uBC1C\uD45C\uB97C
      \uD574\uC57C \uD55C\uB2E4.\n\uBC1C\uD45C \uC2DC\uC791 \uC9C1\uC804\uC774\uB2E4."
