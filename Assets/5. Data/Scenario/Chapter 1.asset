    c1NextId: 
    c2Label: 
    c2NextId: 
    c3Label: 
    c3NextId: 
  - id: 23
    text: "\uC65C \uAE38 \uD55C\uBCF5\uD310\uC5D0\uC11C \uBA4D\uD558\uB2C8 \uC11C
      \uC788\uC5B4?"
    trigger: 0
    nextId: 24
    motionType: 1
    characterType: 3
    backgroundType: 7
    c1Label: 
    c1NextId: 
    c2Label: 
    c2NextId: 
    c3Label: 
    c3NextId: 
  - id: 24
    text: "\uACE0\uAC1C\uB97C \uB4DC\uB2C8 \uCF54\uB05D\uC744 \uC2A4\uCE58\uB294
      \uC775\uC219\uD55C \uC12C\uC720\uC720\uC5F0\uC81C \uB0C4\uC0C8\uC640 \uD568\uAED8,
      \uC5B8\uC81C\uB098\uCC98\uB7FC \uC7A5\uB09C\uAE30 \uAC00\uB4DD\uD55C \uD558\uC9C4\uC774\uC758
      \uC5BC\uAD74\uC774 \uBCF4\uC600\uB2E4."
    trigger: 0
    nextId: 25
    motionType: 0
    characterType: 7
    backgroundType: 7
    c1Label: 
    c1NextId: 
    c2Label: 
    c2NextId: 
    c3Label: 
    c3NextId: 
  - id: 25
    text: "\uADF8 \uC5BC\uAD74\uC744 \uB9C8\uC8FC\uD55C \uC21C\uAC04, \uB048\uC9C8\uAE30\uAC8C
      \uBAA9\uC744 \uC870\uB974\uB358 \uACFC\uD638\uD761\uC774 \uAC00\uB77C\uC549\uC73C\uBA70
      \uAF49 \uB9C9\uD614\uB358 \uC228\uC774 \uD0C1 \uD2B8\uC600\uB2E4."
    trigger: 0
    nextId: 26
    motionType: 0
    characterType: 7
    backgroundType: 7
    c1Label: 
    c1NextId: 
    c2Label: 
    c2NextId: 
    c3Label: 
    c3NextId: 
  - id: 26
    text: "...\uD558\uC9C4\uC544."
    trigger: 0
    nextId: 27
    motionType: 0
    characterType: 1
    backgroundType: 7
    c1Label: 
    c1NextId: 
    c2Label: 
    c2NextId: 
    c3Label: 
    c3NextId: 
  - id: 27
    text: "\uC5BC\uAD74 \uAF34\uC774 \uADF8\uAC8C \uBB50\uB0D0? \uC548 \uBD10\uB3C4
      \uBED4\uD558\uC9C0, \uC784\uB9C8. \uACF5\uD559\uC774\uB77C\uACE0 \uC544\uC8FC
      \uC9C4\uB3D9\uBAA8\uB4DC\uB9C8\uB0E5 \uB5A8\uB4EF \uB5A0\uB124? \uCAC4\uC9C0
      \uB9C8, \uC774 \uBAB8\uC774 \uC606\uC5D0 \uC788\uC796\uC544."
    trigger: 0
    nextId: 28
    motionType: 1
    characterType: 3
    backgroundType: 7
    c1Label: 
    c1NextId: 
    c2Label: 
    c2NextId: 
    c3Label: 
    c3NextId: 
  - id: 28
    text: "\uD558\uC9C4\uC774\uB294 \uB0B4 \uC5B4\uAE68\uB97C \uD22D \uCE58\uB354\uB2C8
      \uC8FC\uBA38\uB2C8\uB97C \uB4A4\uC801\uC5EC \uB538\uAE30 \uB9DB \uC0AC\uD0D5
      \uD558\uB098\uB97C \uAEBC\uB0B4 \uB0B4 \uC785\uC5D0 \uC3D9 \uB123\uC5B4\uC8FC\uC5C8\uB2E4.
      \uB2EC\uCF64\uD55C \uB9DB\uC774 \uC785\uC548\uC5D0 \uD37C\uC9C0\uC790 \uAD73\uC5C8\uB358
      \uC5BC\uAD74 \uADFC\uC721\uC774 \uC870\uAE08\uC740 \uD480\uB9AC\uB294 \uAC83
      \uAC19\uC558\uB2E4."
    trigger: 0
    nextId: 29
    motionType: 0
    characterType: 7
    backgroundType: 7
    c1Label: 
    c1NextId: 
    c2Label: 
    c2NextId: 
    c3Label: 
    c3NextId: 
  - id: 29
    text: "\uB0B4\uAC00 \uC138\uC0C1\uC5D0\uC11C \uC81C\uC77C \uC88B\uC544\uD558\uB294
      \uAC8C \uBC14\uB85C \uC774 \uB538\uAE30 \uB9DB \uC0AC\uD0D5\uC774\uAC70\uB4E0.
      \uD2B9\uBCC4\uD788 \uC591\uBCF4\uD588\uC73C\uB2C8\uAE4C \uD798\uB0B4\uB77C!
      \uC790, \uC6B0\uB9AC \uB300\uBC15 \uB098\uAE38 \uAE30\uB3C4\uD558\uBA74\uC11C
      \uBC18 \uBC30\uCE58\uD45C \uBCF4\uB7EC \uAC00\uC790!"
