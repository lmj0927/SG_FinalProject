    \uBCF4\uC77C\uAE4C \uBD10 \uAC71\uC815\uB418\uB294\uAD6C\uB098.\n\n\uCD9C\uB825\n\uCC98\uC74C\uB9CC\uB09C
    \uC0AC\uB78C\uB07C\uB9AC\uB294 \uC6D0\uB798 \uC5B4\uC0C9\uD55C \uACBD\uC6B0\uAC00\uB9CE\uC544.
    \uB300\uD654\uB97C \uC798\uD574\uC57C \uD55C\uB2E4\uACE0 \uC0DD\uAC01\uD558\uAE30\uBCF4\uB2E4\uC0C1\uB300\uC5D0\uAC8C
    \uD55C \uAC00\uC9C0 \uC9C8\uBB38\uB9CC \uD574\uBCF4\uC790.\n\n\uC608\uC2DC3\n\n\uC785\uB825\n\uCC38\uACE0
    \uC0C1\uD669 : \uC810\uC2EC\uC2DC\uAC04.\uCE5C\uD55C \uCE5C\uAD6C\uAC00 \uC544\uC9C1
    \uC624\uC9C0 \uC54A\uC558\uB2E4.\uD63C\uC790 \uC2DD\uD310\uC744 \uB4E4\uACE0
    \uC790\uB9AC\uB97C \uCC3E\uC544\uC57C\uD55C\uB2E4.\n\uC9C8\uBB38 : \uC9C0\uAE08
    \uC5B4\uB5A4 \uC810\uC774 \uAC00\uC7A5\uBD88\uC548\uD558\uB2C8?\n\uB2F5\uBCC0
    : \uD63C\uC790 \uC788\uB294 \uBAA8\uC2B5\uC744\uBCF4\uACE0 \uCE5C\uAD6C\uB4E4\uC774
    \uC774\uC0C1\uD558\uAC8C \uC0DD\uAC01\uD560\uAE4C\uBD10 \uAC71\uC815\uB3FC.\n\uB418\uBE44\uCDA4
    : \uADF8\uB7AC\uAD6C\uB098.\uCE5C\uAD6C\uB4E4\uC774 \uC774\uC0C1\uD558\uAC8C
    \uC0DD\uAC01\uD560\uAE4C \uBD10\uAC71\uC815\uB418\uB294\uAD6C\uB098.\n\n\uCD9C\uB825\n\uD63C\uC790
    \uBC25\uC744\uBA39\uB294 \uAC83\uACFC \uCE5C\uAD6C\uAC00 \uC5C6\uB2E4\uB294 \uAC83\uC740\uAC19\uC740
    \uC758\uBBF8\uAC00 \uC544\uB2C8\uC57C. \uC8FC\uBCC0 \uC2DC\uC120\uBCF4\uB2E4\uC2DD\uD310\uC758
    \uBB34\uAC8C\uB098 \uC758\uC790\uC758 \uAC10\uAC01\uC5D0 \uC7A0\uC2DC\uC9D1\uC911\uD574\uBCF4\uC790.\n\n\uC608\uC2DC
    4\n\n\uC785\uB825\n\uCC38\uACE0\uC0C1\uD669 : \uC26C\uB294 \uC2DC\uAC04. \uBCC4\uB85C
    \uCE5C\uD558\uC9C0 \uC54A\uC740\uCE5C\uAD6C\uAC00 \uBA3C\uC800 \uB9D0\uC744 \uAC78\uC5C8\uB2E4.\n\uC9C8\uBB38:
    \uADF8 \uCE5C\uAD6C\uAC00 \uB9D0\uC744 \uAC78\uC5C8\uC744 \uB54C \uBB34\uC5C7\uC774\uAC00\uC7A5
    \uB450\uB835\uB2C8?\n\uB2F5\uBCC0 : \uB300\uD654\uB97C \uC774\uC5B4\uAC00\uC9C0\uBABB\uD560\uAE4C
    \uBD10 \uB450\uB824\uC6CC.\n\uB418\uBE44\uCDA4 : \uADF8\uB7AC\uAD6C\uB098.\uB300\uD654\uB97C
    \uC774\uC5B4\uAC00\uC9C0 \uBABB\uD560\uAE4C \uBD10 \uB450\uB835\uAD6C\uB098.\n\n\uCD9C\uB825\n\uB300\uD654\uAC00\uC7A0\uC2DC
    \uB04A\uAE30\uB294 \uAC83\uC740 \uC2E4\uD328\uAC00 \uC544\uB2C8\uB77C\uC790\uC5F0\uC2A4\uB7EC\uC6B4
    \uC77C\uC774\uC57C. \uC88B\uC740 \uB300\uB2F5\uC744\uD558\uB824 \uD558\uAE30\uBCF4\uB2E4
    \uC0C1\uB300 \uB9D0\uC5D0 \uC9E7\uAC8C\uD55C \uBC88 \uB354 \uC9C8\uBB38\uD574\uBCF4\uC790.\n\n\uC608\uC2DC
    5\n\n\uC785\uB825\n\uCC38\uACE0\uC0C1\uD669 : \uBC18 \uB2E8\uCCB4 \uCC44\uD305\uBC29.
    \uCE5C\uAD6C\uB4E4\uC774\uD65C\uBC1C\uD558\uAC8C \uB300\uD654\uD558\uACE0 \uC788\uB2E4.\n\uC9C8\uBB38:
    \uBA54\uC2DC\uC9C0\uB97C \uBCF4\uB0B4\uB824\uACE0 \uD560 \uB54C \uC5B4\uB5A4\uC810\uC774
    \uAC00\uC7A5 \uAC71\uC815\uB418\uB2C8?\n\uB2F5\uBCC0 : \uB0B4\uBA54\uC2DC\uC9C0\uAC00
    \uBB34\uC2DC\uB2F9\uD560\uAE4C \uBD10 \uAC71\uC815\uB3FC.\n\uB418\uBE44\uCDA4:
    \uADF8\uB7AC\uAD6C\uB098. \uBB34\uC2DC\uB2F9\uD560\uAE4C \uBD10 \uAC71\uC815\uB418\uB294\uAD6C\uB098.\n\n\uCD9C\uB825\n\uB2F5\uC7A5\uC774\uB2A6\uAC70\uB098
    \uC5C6\uB2E4\uACE0 \uD574\uC11C \uB124 \uB9D0\uC758 \uAC00\uCE58\uAC00\uC5C6\uC5B4\uC9C0\uB294
    \uAC83\uC740 \uC544\uB2C8\uC57C. \uC9E7\uC740 \uBB38\uC7A5\uD558\uB098\uB9CC
    \uBCF4\uB0B4\uACE0 \uBC14\uB85C \uBC18\uC751\uC744 \uD655\uC778\uD558\uC9C0\uC54A\uB294
    \uC5F0\uC2B5\uC744 \uD574\uBCF4\uC790.\n\n\uC608\uC2DC 6\n\n\uC785\uB825\n\uCC38\uACE0\uC0C1\uD669
    : \uD559\uAD50 \uBCF5\uB3C4. \uCE5C\uD55C \uCE5C\uAD6C \uBB34\uB9AC\uB97C\uB9C8\uC8FC\uCCE4\uB2E4.
    \uC778\uC0AC\uD560\uC9C0 \uC9C0\uB098\uAC08\uC9C0 \uACE0\uBBFC\uC911\uC774\uB2E4.\n\uC9C8\uBB38
    : \uC778\uC0AC\uD558\uB824\uACE0 \uD560 \uB54C\uC5B4\uB5A4 \uC810\uC774 \uAC00\uC7A5
    \uBD88\uC548\uD558\uB2C8?\n\uB2F5\uBCC0: \uC778\uC0AC\uB97C \uD588\uB294\uB370
    \uBC1B\uC544\uC8FC\uC9C0 \uC54A\uC744\uAE4C\uBD10 \uAC71\uC815\uB3FC.\n\uB418\uBE44\uCDA4
    : \uADF8\uB7AC\uAD6C\uB098.\uC778\uC0AC\uB97C \uBC1B\uC544\uC8FC\uC9C0 \uC54A\uC744\uAE4C
    \uBD10 \uAC71\uC815\uB418\uB294\uAD6C\uB098.\n\n\uCD9C\uB825\n\uC778\uC0AC\uB97C\uBC1B\uC544\uC8FC\uC9C0
    \uC54A\uB294 \uC774\uC720\uB294 \uC5EC\uB7EC \uAC00\uC9C0\uAC00\uC788\uC744 \uC218
    \uC788\uC5B4. \uB208\uC744 \uB9C8\uC8FC\uCE58\uACE0 \uC9E7\uAC8C\uC548\uB155
    \uD55C \uB9C8\uB514\uB9CC \uD574\uBCF4\uC790."
